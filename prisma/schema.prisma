/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model training_slots {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  store_owner_id    String              @db.Uuid
  month             String
  slot_number       Int
  status            String?             @default("available")
  created_at        DateTime?           @default(now()) @db.Timestamptz(6)
  training_requests training_requests[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model user_roles {
  user_id    String    @id @db.Uuid
  role       String?
  created_at DateTime? @default(now()) @db.Timestamptz(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model vacancies {
  id                   String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  pharmacy_id          String?     @db.Uuid
  posted_by            String?
  preferred_experience String?
  preferred_shift      String?
  is_active            Boolean?    @default(true)
  created_at           DateTime?   @default(now()) @db.Timestamp(6)
  pharmacies           pharmacies? @relation(fields: [pharmacy_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

// ─────────────────────────────────────────────────────────────────────────────
// MediCLan Khaata Models — multi-tenant accounts management system
// All queries are filtered by storeOwnerId (= Supabase auth user.id)
// ─────────────────────────────────────────────────────────────────────────────

model AppSettings {
  id           Int    @id @default(autoincrement())
  storeOwnerId String @unique
  companyName  String @default("MediCLan")
  gstin        String @default("")
  address      String @default("")
  state        String @default("Maharashtra")
}

model BankAccount {
  id                 Int              @id @default(autoincrement())
  storeOwnerId       String
  name               String
  accountNo          String?
  ifscCode           String?
  accountType        String?
  openingBalance     Float            @default(0)
  openingBalanceDate DateTime?
  isDefault          Boolean          @default(false)
  isActive           Boolean          @default(true)
  bankDeposits       BankDeposit[]
  cheques            Cheque[]
  bankCharges        BankCharge[]
  rdRedemptions      RDRedemption[]
  cardSettlements    CardSettlement[]
  expenses           Expense[]

  @@unique([name, storeOwnerId])
}

model DailyLedger {
  id             Int      @id @default(autoincrement())
  storeOwnerId   String
  date           DateTime
  openingBalance Float
  closingBalance Float
  totalIn        Float
  totalOut       Float

  @@unique([date, storeOwnerId])
}

model Purchase {
  id            Int      @id @default(autoincrement())
  storeOwnerId  String
  date          DateTime
  supplierName  String
  invoiceNumber String
  invoiceAmount Float
  paymentType   String
  chequeId      Int?
  cheque        Cheque?  @relation(fields: [chequeId], references: [id])
}

model Cheque {
  id            Int          @id @default(autoincrement())
  storeOwnerId  String
  chequeNumber  String
  chequeDate    DateTime
  bankName      String
  amount        Float
  status        String
  supplierName  String
  paymentMode   String?
  bankCharge    Float?
  bankAccountId Int?
  bankAccount   BankAccount? @relation(fields: [bankAccountId], references: [id])
  purchases     Purchase[]
  partyType     String       @default("Supplier")
  customerId    Int?
  customer      Customer?    @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model KhataSupplier {
  id           Int     @id @default(autoincrement())
  storeOwnerId String
  name         String
  area         String  @default("")
  phone        String?
  dealsIn      String?
  gstNumber    String?

  @@unique([name, storeOwnerId])
}

model Payment {
  id           Int      @id @default(autoincrement())
  storeOwnerId String
  date         DateTime
  amount       Float
  payee        String
  type         String
  description  String?
}

model Expense {
  id            Int          @id @default(autoincrement())
  storeOwnerId  String
  date          DateTime
  amount        Float
  category      String
  narration     String
  paymentMode   String       @default("Cash")
  bankAccountId Int?
  bankAccount   BankAccount? @relation(fields: [bankAccountId], references: [id])
}

model BankDeposit {
  id            Int          @id @default(autoincrement())
  storeOwnerId  String
  date          DateTime
  amount        Float
  bankName      String
  reference     String?
  narration     String?
  isRD          Boolean      @default(false)
  maturityDate  DateTime?
  bankAccountId Int?
  bankAccount   BankAccount? @relation(fields: [bankAccountId], references: [id])
}

model RDRedemption {
  id                Int          @id @default(autoincrement())
  storeOwnerId      String
  date              DateTime
  amount            Float
  redemptionType    String
  bankAccountId     Int?
  bankAccount       BankAccount? @relation(fields: [bankAccountId], references: [id])
  originalDepositId Int?
  maturityDate      DateTime?
  narration         String?
}

model BankCharge {
  id            Int         @id @default(autoincrement())
  storeOwnerId  String
  date          DateTime
  amount        Float
  bankAccountId Int
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id])
  chargeType    String
  narration     String?
}

model CardSettlement {
  id            Int         @id @default(autoincrement())
  storeOwnerId  String
  date          DateTime
  amount        Float
  bankAccountId Int
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id])
  salesDate     DateTime?
  narration     String?
}

model DailySales {
  id             Int      @id @default(autoincrement())
  storeOwnerId   String
  date           DateTime
  cashSales      Float    @default(0)
  upiSales       Float    @default(0)
  swipeSales     Float    @default(0)
  upiAccountId   Int?
  swipeAccountId Int?

  @@unique([date, storeOwnerId])
}

model Customer {
  id           Int                   @id @default(autoincrement())
  storeOwnerId String
  customerId   String
  name         String
  phone        String
  address      String?               @default("")
  createdAt    DateTime              @default(now())
  transactions CustomerTransaction[]
  cheques      Cheque[]

  @@unique([customerId, storeOwnerId])
}

model CustomerTransaction {
  id            Int      @id @default(autoincrement())
  storeOwnerId  String
  customerId    Int
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type          String
  date          DateTime
  amount        Float
  narration     String?
  invoiceNumber String?
  createdAt     DateTime @default(now())
}

model distributor_formats {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  store_owner_id          String?   @db.Uuid
  party_code              String
  party_name              String
  format_notes            Json      @default("{}")
  last_successful_invoice String?
  updated_at              DateTime? @default(now()) @db.Timestamptz(6)

  @@unique([store_owner_id, party_code])
}
model SimpleLedgerEntry {
  id             Int      @id @default(autoincrement())
  storeOwnerId   String
  date           DateTime
  cashPurchase   Float    @default(0)
  creditPurchase Float    @default(0)
  cashSales      Float    @default(0)
  upiSales       Float    @default(0)
  cardSales      Float    @default(0)

  @@unique([date, storeOwnerId])
}
